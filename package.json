{
  "name": "xeno",
  "version": "1.0.0",
  "private": true,
  "description": "Xeno — 360° virtual tour editor and viewer (static web app) powered by a WebGL panorama engine",
  "author": "Xeno",
  "license": "Apache-2.0",
  "homepage": "https://xeno-tour.com",
  "scripts": {
    "dev": "lr-http-server -p 8080 -d .",
    "engine:watch": "watchify -v -d --noparse=node_modules/**/*.js -s Marzipano -o build/marzipano.js engine/src/index.js",
    "engine:build": "browserify --noparse=node_modules/**/*.js -s Marzipano engine/src/index.js | uglifyjs -c -m > build/marzipano.js"
  },
  "dependencies": {
    "@vercel/blob": "^2.4.0",
    "bowser": "1.9.4",
    "gl-matrix": "3.3.0",
    "hammerjs": "2.0.4",
    "minimal-event-emitter": "1.0.0"
  },
  "devDependencies": {
    "browserify": "^17.0.0",
    "chai": "^4.2.0",
    "jsdoc": "^3.6.6",
    "lr-http-server": "^0.1.5",
    "mocha": "^8.2.1",
    "sinon": "^9.2.2",
    "testem": "^3.2.0",
    "uglify-js": "^3.12.3",
    "watchify": "^3.11.1"
  }
}
